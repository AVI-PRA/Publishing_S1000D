<EditedCommonXsltSource
commonXsltSourceName="Code for the object and image elements"
minorVersion="21" stylerVersion="5">&lt;!--Templates for handling
object for HTML outputs (called from the unmoded match="object" template)-->
&lt;!--This object-related code is used by all HTML outputs but is
not used (never called) for XSL-FO output--> &lt;xsl:template    
        name="handle-object-via-passthrough">   &lt;object>      
&lt;xsl:apply-templates mode="pass-through" select="@*"/>       &lt;!--
If there is a desc child, set the object's title attribute to its
string value -->       &lt;xsl:if test="desc">         &lt;xsl:attribute
name="title">           &lt;xsl:value-of select="desc[1]"/>      
  &lt;/xsl:attribute>       &lt;/xsl:if>       &lt;!-- Pass through
all non-desc children -->       &lt;xsl:apply-templates mode="pass-through"
select="node()[not(self::desc)]"/>    &lt;/object> &lt;/xsl:template>
  &lt;xsl:template  match="*" mode="pass-through">   &lt;xsl:element
name="{name()}">       &lt;xsl:apply-templates mode="pass-through"
select="@*[name()!='class']"/>       &lt;xsl:apply-templates mode="pass-through"/>
   &lt;/xsl:element> &lt;/xsl:template>  &lt;xsl:template match="@*"
mode="pass-through">   &lt;xsl:if test="not(name()='class' or  namespace-uri(.)='http://www.arbortext.com/namespace/Styler/GeneratedTextElements'
or namespace-uri(.)='http://www.arbortext.com/namespace/dita/rdstyle')">
    &lt;xsl:copy-of select="."/>   &lt;/xsl:if> &lt;/xsl:template>
 &lt;xsl:template match="text()|processing-instruction()|comment()"
              mode="pass-through">   &lt;xsl:copy-of select="."/>
&lt;/xsl:template></EditedCommonXsltSource>
