<FootnoteModels>
<FootnoteModel columnOrPageWide="page"
footnoteModelName="Default_Footnotes" footnoteNumberStyle="1"
insertSeparator="yes" separatorAlign="left"
separatorLengthType="specified" separatorRuleLength="9pc"
separatorRuleThickness=".5pt" spaceAboveFootnote="15pt"
spaceBelowSeparator="2pt"/></FootnoteModels>
<Tables>
<TableModel model="cals" primary="yes"/></Tables>
<CustomTables>
<CustomTableModel tableColumnWidthDefault="1*"
tableFosiComposeUsingStylesheet="no" tableModelName="Choice_Table"
tableRulesDefault="all">
<Table columnWidthsAttribute="relcolwidth" element="choicetable"
rulesAttribute="frame"/>
<HeaderRow element="chhead">
<HeaderCell element="chdeschd"></HeaderCell>
<HeaderCell element="choptionhd"></HeaderCell>
</HeaderRow>
<Row element="chrow">
<Cell element="chdesc"></Cell>
<Cell element="choption"></Cell>
</Row>
</CustomTableModel>
<CustomTableModel tableColumnWidthsDefault="1* 3*"
tableModelName="Definition_List">
<Table columnWidthsAttribute="outputclass" element="dl"/>
<HeaderRow element="dlhead">
<HeaderCell element="dthd"></HeaderCell>
<HeaderCell element="ddhd"></HeaderCell>
</HeaderRow>
<Row element="dlentry">
<Cell element="dt"></Cell>
<Cell element="dd"></Cell>
</Row>
</CustomTableModel>
<CustomTableModel
comment="Custom table for creating a diagnostic procedure."
tableFosiComposeUsingStylesheet="no" tableModelName="Diagnostic_Table">
<Table element="diagtable"/>
<HeaderRow element="diaghead">
<HeaderCell element="diagheadentry"></HeaderCell>
</HeaderRow>
<Row element="diagrow">
<Cell element="diagobservation"></Cell>
<Cell element="diagtitle"></Cell>
<Cell element="diagtest"></Cell>
<Cell element="diagresult"></Cell>
</Row>
</CustomTableModel>
<CustomTableModel tableColumnWidthDefault="1*"
tableColumnWidthsDefault="1* 3*" tableModelName="Glossary_Table">
<Table columnWidthsAttribute="outputclass" element="glossarylist"/>
<Row element="glossentry">
<Cell element="glossterm"></Cell>
<Cell element="glossdef"></Cell>
</Row>
</CustomTableModel>
<CustomTableModel restartShadingPattern="yes"
tableColumnWidthsDefault="0.5* 1.5* 2.5* 0.5* 2.5*"
tableModelName="Parts_List">
<Table element="partlist"/>
<HeaderRow
cellOrder="itemNumber-h partNumber-h partName-h quantity-h remarks-h"
element="_sfe:GeneratedHeaderRow_Parts_List" generate="yes">
<HeaderCell element="_sfe:GeneratedHeaderCell_itemNumber-h_Parts_List"
generatedCellName="itemNumber-h" generatedCellXPath="'Item No.'">
</HeaderCell>
<HeaderCell element="_sfe:GeneratedHeaderCell_partNumber-h_Parts_List"
generatedCellName="partNumber-h" generatedCellXPath="'Part Number'">
</HeaderCell>
<HeaderCell element="_sfe:GeneratedHeaderCell_partName-h_Parts_List"
generatedCellName="partName-h" generatedCellXPath="'Part Name'">
</HeaderCell>
<HeaderCell element="_sfe:GeneratedHeaderCell_quantity-h_Parts_List"
generatedCellName="quantity-h" generatedCellXPath="'QTY'"></HeaderCell>
<HeaderCell element="_sfe:GeneratedHeaderCell_remarks-h_Parts_List"
generatedCellName="remarks-h" generatedCellXPath="'Remarks'">
</HeaderCell>
</HeaderRow>
<Row cellOrder="itemNumber partNumber partName quantity remarks"
element="partitem">
<CustomTableSetAttributes>
<SetAttribute attributeName="ipd-illustrated"
attributeValueXPath="partattribute[@name='illustrated']"/>
<SetAttribute attributeName="ipd-serviceable"
attributeValueXPath="partattribute[@name='spareable']"/>
<SetAttribute attributeName="ipd-indenture"
attributeValueXPath="partattribute[@name='indenture']"/>
<SetAttribute attributeName="ipd-sequence"
attributeValueXPath="partattribute[@name='itemSequenceNumber.value']"/>
<SetAttribute attributeName="ipd-partNumber"
attributeValueXPath='partattribute[@name="number"]'/>
</CustomTableSetAttributes>
<Cell element="_sfe:GeneratedCell_itemNumber_Parts_List"
generatedCellName="itemNumber" generatedCellXPath="''">
<CustomTableSetAttributes>
<SetAttribute attributeName="ipd-itemnumber"
attributeValueXPath='partattribute[@name="itemNumber"]'/>
</CustomTableSetAttributes>
</Cell>
<Cell element="_sfe:GeneratedCell_partNumber_Parts_List"
generatedCellName="partNumber" generatedCellXPath="''"></Cell>
<Cell element="_sfe:GeneratedCell_partName_Parts_List"
generatedCellName="partName"
generatedCellXPath='partattribute[@name="name"]/node()'></Cell>
<Cell element="_sfe:GeneratedCell_quantity_Parts_List"
generatedCellName="quantity"
generatedCellXPath='partattribute[@name="itemQuantity"]/node()'></Cell>
<Cell element="_sfe:GeneratedCell_remarks_Parts_List"
generatedCellName="remarks"
generatedCellXPath='partattribute[@name="remarks"]/node()'></Cell>
</Row>
<HeaderRowShading rowShadingColor="#D0D0D0"/>
<RowShading rowShadingColor="transparent"/>
<RowShading rowShadingColor="#E0E0E0"/></CustomTableModel>
<CustomTableModel tableColumnWidthDefault="1*"
tableColumnWidthsDefault="1* 1* 2*" tableFosiComposeUsingStylesheet="no"
tableModelName="Properties_Table" tableRulesDefault="all">
<Table element="properties"/>
<HeaderRow element="prophead">
<HeaderCell element="proptypehd"></HeaderCell>
<HeaderCell element="propvaluehd"></HeaderCell>
<HeaderCell element="propdeschd"></HeaderCell>
</HeaderRow>
<Row element="property">
<Cell element="proptype"></Cell>
<Cell element="propvalue"></Cell>
<Cell element="propdesc"></Cell>
</Row>
</CustomTableModel>
<CustomTableModel tableColumnWidthDefault="1*"
tableFosiComposeUsingStylesheet="no" tableModelName="Relationship_Table"
tableRulesDefault="all">
<Table element="reltable"/>
<HeaderRow element="relheader"></HeaderRow>
<Row element="relrow">
<Cell element="relcell"></Cell>
</Row>
</CustomTableModel>
<CustomTableModel tableColumnWidthDefault="1*"
tableFosiComposeUsingStylesheet="no" tableModelName="Simple_Table"
tableRulesDefault="all">
<Table columnWidthsAttribute="relcolwidth" element="simpletable"
rulesAttribute="frame"/>
<HeaderRow element="sthead">
<HeaderCell element="stentry"></HeaderCell>
</HeaderRow>
<Row element="strow">
<Cell element="stentry"></Cell>
</Row>
</CustomTableModel>
</CustomTables>
