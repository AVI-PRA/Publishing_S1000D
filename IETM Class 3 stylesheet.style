<Element name="object" style="block">
<Context align="left" blockOrInline="block"
comment='To recreate the edited source for object, delete all edited source and regenerate it for all HTML outputs. Then replace the xsl:apply-templates within the unmoded match="object" template with a call to template name="handle-object-via-passthrough" (which, along with some templates it calls, is defined in Edited Common XSLT source).'
foClass="block" hidden="no" priority="0" selector="object"
startNew="none">
<BaseProperties propertySetReferences="spacebeforemedium">
<Breaks blockOrInline="block"/></BaseProperties>
<EditedSource minorVersion="21" sourceType="xslWeb" stylerVersion="5"
>&lt;!--Style
template for Context: object-->&lt;xsl:template
name="__style-for_object.1"
xmlns:xsl="http://www.w3.org/1999/XSL/Transform">       &lt;xsl:text
> .x-object-1-0 {margin-left: 0pt; margin-right: 0pt; text-indent:
0pt; margin-top: 7pt; }&lt;/xsl:text>    &lt;/xsl:template>&lt;!--Template
for Context: object-->&lt;xsl:template
match="object" priority="0"
xmlns:xsl="http://www.w3.org/1999/XSL/Transform">       &lt;div
xmlns:dmp="http://www.arbortext.com/namespace/dmp/dmpmap">&lt;!--Emit
class values to reflect conditions-->&lt;xsl:attribute
name="class">             &lt;xsl:text> x-object-1-0&lt;/xsl:text>
    
    &lt;/xsl:attribute>          &lt;xsl:copy-of select="@ch:*"/>
     
   &lt;xsl:copy-of select="@dmp:*"/>          &lt;xsl:call-template
name="maybe-set-id">&lt;/xsl:call-template>          &lt;!--EDITED
SOURCE CHANGE: replace apply-templates with a call to handle-object-via-passthrough-->&lt;xsl:call-template
name="handle-object-via-passthrough">&lt;/xsl:call-template>     
 &lt;/div
>    &lt;/xsl:template>&lt;!--Gentext template for Context: object-->&lt;xsl:template
match="object" mode="expand-gentext" priority="0"
xmlns:xsl="http://www.w3.org/1999/XSL/Transform">       &lt;xsl:copy
>          &lt;xsl:attribute name="_gte:Gentext-Expanded">y&lt;/xsl:attribute
>          &lt;xsl:apply-templates mode="expand-gentext" select="@*">
&lt;/xsl:apply-templates>          &lt;xsl:if test="not(@_gte:id)">
   
        &lt;xsl:attribute name="_gte:id">                &lt;xsl:value-of
select="'_g_'"/>                &lt;xsl:value-of select="generate-id(.)"
/>             &lt;/xsl:attribute>          &lt;/xsl:if>         
&lt;xsl:apply-templates
mode="expand-gentext" select="* | text() | processing-instruction()">
&lt;/xsl:apply-templates>       &lt;/xsl:copy>    &lt;/xsl:template>&lt;!--Initial
pass template for Context: object-->&lt;xsl:template
match="object" mode="initial-pass-mode" priority="0"
xmlns:xsl="http://www.w3.org/1999/XSL/Transform">       &lt;xsl:copy
>          &lt;xsl:call-template name="maybe-set-gte-id">
&lt;/xsl:call-template>          &lt;xsl:apply-templates
mode="initial-pass-mode" select="@*|node()">&lt;/xsl:apply-templates
>       &lt;/xsl:copy>    &lt;/xsl:template>&lt;!--Set count-as pass
template for Context: object-->&lt;xsl:template
match="object" mode="set-countas" priority="0"
xmlns:xsl="http://www.w3.org/1999/XSL/Transform">       &lt;xsl:copy
>          &lt;xsl:apply-templates mode="set-countas" select="@*|node()">
&lt;/xsl:apply-templates>       &lt;/xsl:copy>    &lt;/xsl:template>&lt;!--Set
ch:chunk template for Context: object-->&lt;xsl:template
match="object" mode="set-ch-chunk" priority="0"
xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
xmlns:dmp="http://www.arbortext.com/namespace/dmp/dmpmap">       &lt;xsl:copy
>          &lt;xsl:if test="not(@_gte:did-set-chunk)">           
 &lt;xsl:if
test="@ch:boundary = 'yes'">                &lt;xsl:attribute
name="ch:chunk">yes&lt;/xsl:attribute>             &lt;/xsl:if>  
     
    &lt;xsl:attribute name="_gte:did-set-chunk">yes&lt;/xsl:attribute>

        &lt;/xsl:if>          &lt;xsl:apply-templates mode="set-ch-chunk"
select="@*|node()">&lt;/xsl:apply-templates>       &lt;/xsl:copy>
   &lt;/xsl:template
></EditedSource>
