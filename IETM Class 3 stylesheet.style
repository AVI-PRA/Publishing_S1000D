<PropertySet
comment="This property set has FOSI and XSL-FO edited source to set the necessary left indent for the info element so that right aligned side by side works in FOSI and XSL-FO print/PDF without interfering with HTML or APP outputs which utilize the offset."
propertySetId="FOSI_and_XSL-FO_info_indent">
<BaseProperties></BaseProperties>
<EditedSource minorVersion="0" productVersion="6.0F000"
sourceType="xslFo" stylerVersion="6">&lt;!--This property set has FOSI and XSL-FO edited source to set the necessary left indent for the info element so that right aligned side by side works in FOSI and XSL-FO print/PDF without interfering with HTML or APP outputs which utilize the offset.-->&lt;xsl:template
name="ps-FOSI_and_XSL-FO_info_indent">       &lt;xsl:attribute
name="margin-left">20pc&lt;/xsl:attribute>       &lt;xsl:attribute
name="text-indent">0pt&lt;/xsl:attribute>    &lt;/xsl:template></EditedSource>
<EditedSource minorVersion="0" productVersion="6.0F000"
sourceType="fosi" stylerVersion="6">&lt;!--This property set has FOSI and XSL-FO edited source to set the necessary left indent for the info element so that right aligned side by side works in FOSI and XSL-FO print/PDF without interfering with HTML or APP outputs which utilize the offset.-->&lt;charsubset
charsubsetid="FOSI_and_XSL-FO_info_indent">
&lt;indent leftind="@20pc"/>&lt;/charsubset></EditedSource>
</PropertySet>
<PropertySet propertySetId="FrameAll">
<BaseProperties></BaseProperties>
<EditedSource minorVersion="23" sourceType="app" stylerVersion="5"
><OnEnter type="application/x-javascript" xml:space="preserve"><![CDATA[//APP source for applying boxing around a block - FrameAll. This should not be applied to inline elements.
var block = arguments[0];
var paragraph = block.defaultParagraph;
var style = block.defaultStyle;

//Apply a -1.399pt rule to the block to offset the main rule
var rule = new fRule();
with (rule) {
   thickness = "-1.399pt";
   lineColor = "None";
   sides = "tblr";
}
block.rules.addRule(rule);

//Apply the main rule to the block
var rule = new fRule();
with (rule) {
   //Line thickness
   thickness = ".4pt";
   //Line colour
   lineColor = "Black";
   //Sides (top, bottom, left and right)
   sides = "tblr";
}
block.rules.addRule(rule);

//Apply a final rule to the block to remove the offset
var rule = new fRule();
with (rule) {
   thickness = "1pt";
   lineColor = "None";
   sides = "tblr";
}
block.rules.addRule(rule);

]]></OnEnter><OnExit type="application/x-javascript"
xml:space="preserve"><![CDATA[/* commands to execute before leaving a node go here */
]]></OnExit></EditedSource>
<EditedSource sourceType="fosi">&lt;charsubset
charsubsetid="FrameAll">
